# --- ZOI Agent (produção) — Castro Veículos ---
# Copie este arquivo para .env.prod e preencha. NÃO COMMITAR .env.prod.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_UPDATER=gpt-4o
OPENAI_MODEL_RESPONDER=gpt-4o
OPENAI_MODEL_INVENTORY_EXTRACTOR=gpt-4o-mini
OPENAI_MODEL_WHISPER=whisper-1

# GHL (PIT single-tenant)
GHL_PIT_TOKEN=pit-...
GHL_LOCATION_ID=p8ycojDHuDM5HZnNwLAi
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# GHL — Custom Values
GHL_STOCK_CUSTOM_VALUE_ID=wsiONlTe5wu3Okrv1z63
GHL_FAQ_CUSTOM_VALUE_ID=kLKrZS2MosXS5dANroF9

# GHL — Custom Fields (contact)
GHL_FIELD_VEICULO_INTERESSE=gAY6MsVjAEZh5ccfpQWb
GHL_FIELD_SAUDACAO_PREVENDAS=PQ7BsMjIAwHjNUR0WSgZ

# GHL — Calendar
GHL_CALENDAR_ID=vuhStWyJ3l67AYYoAVyL
GHL_APPOINTMENT_DURATION_MIN=60

# GHL — Workflows
GHL_HANDOFF_WORKFLOW_ID=bf3fb46d-22b8-4b72-a7b4-4e10a96f5c10

# GHL — Tags
GHL_TAG_AGENT_GATE=agente-ia

# Server — gere um secret novo via: openssl rand -hex 32
WEBHOOK_SECRET=
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=America/Sao_Paulo

# Postgres — senha forte (também usada pelo container Postgres)
POSTGRES_PASSWORD=

# Cache TTL
FAQ_CACHE_TTL_SECONDS=300
STOCK_CACHE_TTL_SECONDS=300

# Limits
CONVERSATION_HISTORY_LIMIT=100
INVENTORY_SEARCH_LIMIT=10
RESPONDER_MAX_BUBBLES=3
RESPONDER_SLEEP_MIN=0.6
RESPONDER_SLEEP_MAX=1.2
HUMAN_REQUEST_THRESHOLD=2
AI_IDENTITY_ADMIT_AT=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
