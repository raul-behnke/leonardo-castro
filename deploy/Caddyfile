# Caddy auto-obtém TLS via Let's Encrypt na 1ª subida.
# Pré-requisito: DNS A de lucas-amc.appzoi.com.br apontando pro IP da VPS.

lucas-amc.appzoi.com.br {
    encode gzip zstd

    # Endpoints públicos do agente
    reverse_proxy app:8000

    # Métricas restritas — descomente e ajuste se quiser proteger /metrics:
    # @metrics path /metrics
    # handle @metrics {
    #     basic_auth {
    #         admin <COLE_AQUI_O_HASH_BCRYPT>
    #     }
    #     reverse_proxy app:8000
    # }

    log {
        output stdout
        format json
        level INFO
    }
}
